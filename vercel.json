{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/api/generate/history",
            "destination": "/api/history"
        },
        {
            "source": "/api/upload",
            "destination": "/api/upload"
        },
        {
            "source": "/api/generate",
            "destination": "/api/generate"
        }
    ]
}